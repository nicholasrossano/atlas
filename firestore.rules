rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only catalog for the map UI. Writes stay server-side (Admin SDK).
    match /atlasBooks/{bookId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
